    {
      "type": "text",
      "id": "control_text",
      "x": 522,
      "y": 212,
      "width": 456,
      "height": 240,
      "text": "route by intent + scope\nread once, then compile\nturn cache on hot paths\nrank by freshness + trust + provenance\nreject stale or contested facts\nscore quality so gaps stay visible",
