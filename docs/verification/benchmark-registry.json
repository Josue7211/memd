    {
      "id": "verifier.feature.bundle.resume",
      "name": "Resume feature contract",
      "type": "feature_contract",
      "pillar": "memory-continuity",
      "family": "bundle-runtime",
      "subject_ids": ["feature.bundle.resume"],
      "fixture_id": "fixture.continuity_bundle",
      "baseline_modes": ["with_memd"],
      "steps": [
        {
          "kind": "cli",
          "run": "memd checkpoint --output {{bundle}}"
        },
        {
          "kind": "cli",
          "run": "memd resume --output {{bundle}}"
        }
      ],
      "assertions": [
        {
          "kind": "json_path",
          "path": "resume.current_task.id",
          "equals_fixture": "task.id"
        },
        {
          "kind": "json_path",
          "path": "resume.current_task.id",
          "exists": true
        }
      ],
      "metrics": ["latency_ms", "prompt_tokens"],
      "evidence_requirements": ["live_primary"],
      "gate_target": "acceptable",
      "status": "declared",
      "lanes": ["fast", "nightly"],
      "helper_hooks": []
    },
