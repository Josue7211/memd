{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "memd whole-app feature registry",
  "type": "object",
  "required": [
    "version",
    "purpose",
    "status_vocabulary",
    "proof_vocabularies",
    "features"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "status_vocabulary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof_vocabularies": {
      "type": "object"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "user_contract",
          "implementation_surfaces",
          "docs",
          "proof_commands",
          "proof_artifacts",
          "current_status",
          "proof_status",
          "dogfood_status",
          "external_status",
          "blocks_25_25",
          "scorecard_axes",
          "allowed_claims",
          "forbidden_claims",
          "freshness_policy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^feature\\.[a-z0-9][a-z0-9._-]*$"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "user_contract": {
            "type": "string"
          },
          "implementation_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "docs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proof_commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proof_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "current_status": {
            "type": "string",
            "enum": [
              "not_started",
              "stub",
              "partial",
              "implemented",
              "broken",
              "unknown"
            ]
          },
          "proof_status": {
            "type": "string",
            "enum": [
              "none",
              "planned",
              "smoke",
              "partial",
              "strong",
              "external_verified",
              "stale"
            ]
          },
          "dogfood_status": {
            "type": "string",
            "enum": [
              "none",
              "planned",
              "ad_hoc",
              "windowed",
              "continuous",
              "stale"
            ]
          },
          "external_status": {
            "type": "string",
            "enum": [
              "none",
              "planned",
              "replayable",
              "external_verified",
              "stale"
            ]
          },
          "blocks_25_25": {
            "type": "boolean"
          },
          "scorecard_axes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "freshness_policy": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
