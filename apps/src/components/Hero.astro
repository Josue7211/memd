---
const { eyebrow, title, description, primaryCta, secondaryCta, bullets, cards, badge } = Astro.props;
---

<section class="hero section" id="cloud" data-reveal>
  <div class="container">
    <div class="hero-sales panel" data-reactive>
      <div class="hero-sales__copy">
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="hero-description">{description}</p>

        <div class="hero-actions">
          <a class="button button-solid" href={primaryCta.href}>{primaryCta.label}</a>
          <a class="button button-ghost" href={secondaryCta.href}>{secondaryCta.label}</a>
        </div>

        <ul class="hero-bullets">
          {bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
      </div>

      <div class="hero-sales__visual">
        <div class="hero-sales__badge">{badge}</div>
        <div class="hero-sales__panel">
          <div class="hero-sales__panel-head">
            <span>memd cloud</span>
            <span>paid beta</span>
          </div>
          <div class="hero-sales__cards">
            {cards.map((card) => (
              <article class:list={["hero-sales-card", card.featured && "hero-sales-card--featured"]}>
                <p class="hero-sales-card__label">{card.label}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
              </article>
            ))}
          </div>
          <div class="hero-sales__footer">
            <span>source-linked</span>
            <span>fresh</span>
            <span>recoverable</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
