# A3-D5: the live memory contract is the published shape — track it.
!/.memd/contract.json
# A3 Part 2: hook scripts are part of the continuity foundation.
!/.memd/hooks/
!/.memd/hooks/**
# G5: re-include only the small documentation fixtures consumed by
# substrate render tests; runtime artefacts under .memd/benchmarks/
# (results/, baselines/, datasets/, etc.) stay ignored.
!/.memd/benchmarks/
/.memd/benchmarks/*
!/.memd/benchmarks/substrate/
/.memd/benchmarks/substrate/*
!/.memd/benchmarks/substrate/fixtures/
/.memd/benchmarks/substrate/fixtures/*
!/.memd/benchmarks/substrate/fixtures/g5/
!/.memd/benchmarks/substrate/fixtures/g5/**
# D6: bench-compiler budget profile is a published contract artefact.
!/.memd/benchmarks/public/
/.memd/benchmarks/public/*
!/.memd/benchmarks/public/compiler-budgets.json
